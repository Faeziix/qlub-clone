# Copy to .env and fill in real values. .env is gitignored and must never be committed.

# ── Database ─────────────────────────────────────────────────────────────────
# Pooled connection for the app server (PgBouncer / Neon pooler).
# Get both URLs from your Neon project dashboard → Connection Details.
DATABASE_URL="postgresql://user:password@pooler-host:5432/dbname?sslmode=require"

# Unpooled (direct) connection used by Prisma migrations to bypass the pooler.
# Required whenever DATABASE_URL is a pooled connection.
DIRECT_URL="postgresql://user:password@direct-host:5432/dbname?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required. The app refuses to start without it.
# Generate a strong value: openssl rand -base64 48
AUTH_SECRET=""

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="qlub"

# Public URL of the app — used for CSRF/origin validation on public POST routes.
# Example: https://qlub.ir
NEXT_PUBLIC_APP_URL=""

# ── Rate limiting (Redis) ─────────────────────────────────────────────────────
# Production MUST set REDIS_URL for multi-instance correctness: the in-memory
# adapter is the dev/single-instance fallback, but its state is not shared
# across processes and is lost on restart.
#
# Upstash (recommended for Track A/Neon stack):
#   REDIS_URL="rediss://default:<token>@<host>.upstash.io:6380"
#
# Domestic Redis (Track B, production Iran):
#   REDIS_URL="redis://:<password>@<host>:6379"
REDIS_URL=""

# ── SMS OTP providers (issue #18) ─────────────────────────────────────────────
# Primary and fallback SMS providers for guest phone OTP verification.
# When credentials are absent:
#   - In development/test: a console adapter logs the OTP code (no SMS sent).
#   - In production: the SMS service reports "unavailable"; payment proceeds
#     without OTP (graceful degradation), and operators can use the override.
#
# The adapters POST to the provider API with the x-api-key header. Payload:
#   Primary:  { "receptor": "<E.164>", "sender": "<line>", "message": "<text>" }
#   Fallback: { "to": "<E.164>", "from": "<line>", "text": "<text>" }
SMS_PRIMARY_API_KEY=""
SMS_PRIMARY_LINE_NUMBER=""
SMS_PRIMARY_API_URL=""

SMS_FALLBACK_API_KEY=""
SMS_FALLBACK_LINE_NUMBER=""
SMS_FALLBACK_API_URL=""

# ── Payments — PaymentProvider selection (issue #20) ─────────────────────────
# Selects the active payment facilitator adapter at runtime.
# Defaults to "simulated" when unset — the app, tests, and build run with no
# external gateway account in this mode.
#
# Valid values:
#   simulated / sandbox  — in-process simulation (default; safe for CI/dev/staging)
#   [live adapters added under issue #5 once the facilitator is chosen]
#
# Do NOT set a live facilitator value here until issue #5 is resolved and the
# facilitator's live API contract has been re-verified (field names, result
# codes, ceilings — see PRD §6.1 caution note).
PAYMENT_PROVIDER="simulated"

# ── Seeding (non-production only) ─────────────────────────────────────────────
# Set SEED_DEMO=true in non-production to seed demo staff accounts and surface
# them on the admin login page. Never set in production.
SEED_DEMO=""
