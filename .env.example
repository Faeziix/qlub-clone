# Copy to .env and fill in real values. .env is gitignored and must never be committed.

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development default — zero-config local dev):
DATABASE_URL="file:./dev.db"
# PostgreSQL (staging / production — use a pooled URL for the app server):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# DIRECT_URL is required when DATABASE_URL is a pooled connection (e.g. PgBouncer / Neon pooler).
# Prisma migrations use DIRECT_URL to bypass the pooler.
# Leave unset for SQLite or direct (non-pooled) Postgres connections.
# DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required. The app refuses to start without it.
# Generate a strong value: openssl rand -base64 48
AUTH_SECRET=""

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="qlub"

# ── Seeding (non-production only) ─────────────────────────────────────────────
# Set SEED_DEMO=true in non-production to seed demo staff accounts and surface
# them on the admin login page. Never set in production.
SEED_DEMO=""
