{
  "name": "qlub-clone",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready clone of qlub.io — QR pay-at-table + ordering app and restaurant management platform",
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && bun run db:seed",
    "db:studio": "prisma studio",
    "setup": "prisma generate && prisma db push && bun run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "eslint-config-next": "^16.2.9",
    "jose": "^5.10.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.16",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9",
    "fast-check": "^4.8.0",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
