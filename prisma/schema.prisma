// Qlub Iran — data model for QR pay-at-table ordering + restaurant management.
// SQLite for zero-config local/dev; switch provider to "postgresql" for production.
// Issue #8: native enums, native Json, Iran defaults, translation tables,
//           per-vendor orderNumber sequence, AuditLog, sub-merchant fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────── Enums ──────────────────────────────────────

enum OrderStatus {
  open
  placed
  preparing
  ready
  served
  paid
  cancelled
}

enum OrderType {
  qsr
  dinein
}

enum OrderSource {
  qr
  pos
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
  expired
}

/// Iran-legal payment methods.
/// card_to_card is excluded — it is not a settled split method (PRD §6).
/// UAE-era methods (tabby, benefit, apple_pay, google_pay) are removed.
enum PaymentMethod {
  ipg
  cash
}

enum SplitType {
  full
  even
  items
  custom
}

enum StaffRole {
  superadmin
  owner
  manager
  staff
}

enum TableStatus {
  available
  occupied
  bill_requested
}

/// eNamad onboarding state for a vendor sub-merchant.
enum EnamadStatus {
  none
  pending
  verified
  rejected
}

// ─────────────────────────── Tenancy & branding ───────────────────────────

model Vendor {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  country         String   @default("ir")
  currency        String   @default("IRR")
  locale          String   @default("fa")
  description     String?
  logoUrl         String?
  coverUrl        String?
  theme           String   @default("darkgold")
  supportedLangs  Json     @default("[\"fa\",\"en\"]")
  address         String?
  phone           String?
  email           String?
  timezone        String   @default("Asia/Tehran")

  // Billing config — percentages stay Float; money columns use BigInt
  serviceChargePct Float   @default(0)
  taxPct           Float   @default(0)
  taxInclusive     Boolean @default(true)
  // VAT is off by default; must be enabled per-vendor by the owner (pending Iranian accountant sign-off)
  vatEnabled       Boolean @default(false)
  vatPct           Float   @default(0)
  tippingEnabled   Boolean @default(true)
  tipPresets       Json    @default("[5,10,15]")
  payAtTable       Boolean @default(true)
  qsrOrdering      Boolean @default(true)

  // Per-vendor monotonic order-number counter.
  // Incremented inside a SELECT … FOR UPDATE transaction in createOrderFromCart.
  vendorOrderSeq   Int     @default(0)

  // Sub-merchant onboarding fields (Phase 4/5 gateway integration)
  gatewaySubMerchantId String?
  payoutIban           String?
  ibanVerifiedAt       DateTime?
  nationalId           String?
  eNamadStatus         EnamadStatus @default(none)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menus      Menu[]
  items      MenuItem[]
  tables     DiningTable[]
  orders     Order[]
  payments   Payment[]
  reviews    Review[]
  staff      StaffUser[]
  auditLogs  AuditLog[]
}

// ───────────────────────────── Menu structure ─────────────────────────────

model Menu {
  id           String  @id @default(cuid())
  vendorId     String
  name         String
  imageUrl     String?
  sortOrder    Int     @default(0)
  active       Boolean @default(true)
  availability Json?

  vendor     Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  categories Category[]

  @@index([vendorId])
}

model Category {
  id        String @id @default(cuid())
  menuId    String
  name      String
  sortOrder Int    @default(0)

  menu         Menu                  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items        MenuItem[]
  translations CategoryTranslation[]

  @@index([menuId])
}

model CategoryTranslation {
  id         String @id @default(cuid())
  categoryId String
  locale     String
  name       String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([categoryId])
}

model MenuItem {
  id          String  @id @default(cuid())
  vendorId    String
  categoryId  String
  name        String
  description String?
  price       BigInt
  imageUrl    String?
  sortOrder   Int     @default(0)
  available   Boolean @default(true)
  calories    Int?
  tags        Json    @default("[]")

  vendor         Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category       Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modifierGroups ModifierGroup[]
  translations   MenuItemTranslation[]

  @@index([categoryId])
  @@index([vendorId])
}

model MenuItemTranslation {
  id          String  @id @default(cuid())
  menuItemId  String
  locale      String
  name        String
  description String?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, locale])
  @@index([menuItemId])
}

model ModifierGroup {
  id        String  @id @default(cuid())
  itemId    String
  name      String
  minSelect Int     @default(0)
  maxSelect Int     @default(1)
  required  Boolean @default(false)
  sortOrder Int     @default(0)

  item         MenuItem                    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options      ModifierOption[]
  translations ModifierGroupTranslation[]

  @@index([itemId])
}

model ModifierGroupTranslation {
  id              String @id @default(cuid())
  modifierGroupId String
  locale          String
  name            String

  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([modifierGroupId, locale])
  @@index([modifierGroupId])
}

model ModifierOption {
  id         String  @id @default(cuid())
  groupId    String
  name       String
  priceDelta BigInt  @default(0)
  isDefault  Boolean @default(false)
  sortOrder  Int     @default(0)

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// ─────────────────────────── Tables & QR codes ────────────────────────────

model DiningTable {
  id        String      @id @default(cuid())
  vendorId  String
  code      String
  label     String?
  passcode  String
  seats     Int         @default(2)
  area      String?
  status    TableStatus @default(available)
  createdAt DateTime    @default(now())

  vendor Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([vendorId, code])
  @@index([vendorId])
}

// ──────────────────────────── Orders & payments ───────────────────────────

model Order {
  id          String      @id @default(cuid())
  vendorId    String
  tableId     String?
  /// Per-vendor monotonic order number. Unique only within a vendor.
  /// Formatted as "V-000001". See Vendor.vendorOrderSeq.
  orderNumber String
  type        OrderType   @default(qsr)
  status      OrderStatus @default(open)
  source      OrderSource @default(qr)

  guestName  String?
  guestPhone String?
  notes      String?

  currency      String @default("IRR")
  subtotal      BigInt @default(0)
  serviceCharge BigInt @default(0)
  tax           BigInt @default(0)
  discount      BigInt @default(0)
  tipAmount     BigInt @default(0)
  total         BigInt @default(0)
  amountPaid    BigInt @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor   Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  table    DiningTable? @relation(fields: [tableId], references: [id])
  items    OrderItem[]
  payments Payment[]

  /// Per-vendor orderNumber is unique — no two orders for the same vendor share a number.
  @@unique([vendorId, orderNumber])
  @@index([vendorId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  itemId    String?
  name      String
  unitPrice BigInt
  quantity  Int     @default(1)
  modifiers Json    @default("[]")
  notes     String?
  lineTotal BigInt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id        String        @id @default(cuid())
  vendorId  String
  orderId   String
  amount    BigInt
  tipAmount BigInt        @default(0)
  total     BigInt
  currency  String        @default("IRR")
  method    PaymentMethod @default(ipg)
  status    PaymentStatus @default(pending)
  splitType SplitType     @default(full)
  splitMeta Json?
  payerName  String?
  payerEmail String?
  reference  String        @unique
  createdAt  DateTime      @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  review Review?

  @@index([orderId])
  @@index([vendorId])
}

/// Review is per-Payment (not per-Order) — resolves split-bill review ownership (ADR-0007).
/// Each verified payer may review exactly once via their Payment.
model Review {
  id             String   @id @default(cuid())
  vendorId       String
  paymentId      String   @unique
  rating         Int
  foodRating     Int?
  serviceRating  Int?
  ambienceRating Int?
  comment        String?
  guestName      String?
  createdAt      DateTime @default(now())

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([vendorId])
}

// ──────────────────────────── Admin / staff auth ──────────────────────────

model StaffUser {
  id           String    @id @default(cuid())
  vendorId     String?
  email        String    @unique
  passwordHash String
  name         String
  role         StaffRole @default(manager)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  vendor    Vendor?    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([vendorId])
}

// ──────────────────────────── Audit log ──────────────────────────────────

/// Append-only audit trail for admin mutations and logins.
/// actorId references StaffUser.id. vendorId is null for superadmin cross-tenant actions.
model AuditLog {
  id       String   @id @default(cuid())
  actorId  String
  vendorId String?
  action   String
  entity   String
  entityId String
  before   Json?
  after    Json?
  at       DateTime @default(now())

  actor  StaffUser @relation(fields: [actorId], references: [id])
  vendor Vendor?   @relation(fields: [vendorId], references: [id])

  @@index([actorId])
  @@index([vendorId])
  @@index([entity, entityId])
  @@index([at])
}
